# ===== Synthea (data generator) =====
# 931MB cloned repo + its raw generated output — NEVER commit.
# Teammates regenerate locally (see data/README.md).
data/synthea/
data/**/output/

# Keep the curated seed bundles the backend ingests.
# (small, hand-picked FHIR JSON — commit these)
!data/seed/
!data/seed/**

# ===== Java / Maven (backend) =====
backend/target/
*.class

# ===== Node / Next (frontend) =====
frontend/node_modules/
frontend/.next/
frontend/out/
npm-debug.log*

# ===== IDE =====
.idea/
*.iml

# ===== Secrets / env (ANTHROPIC_API_KEY, DB creds) =====
.env
.env.*
!.env.example

# ===== OS junk =====
.DS_Store
Thumbs.db

# ===== Python / AIML service =====
aiml/.venv/
aiml/venv/
aiml/__pycache__/
aiml/**/__pycache__/
aiml/**/*.pyc
aiml/**/*.pyo
aiml/.pytest_cache/
aiml/*.egg-info/

# Trained model artifacts (generated by prediction/train.py)
aiml/models/*.pkl
aiml/models/*.joblib

# AIML secrets — teammates copy .env.example → .env
aiml/.env

# Generated SQLite data layer (rebuilt from data/seed/fhir on first startup)
aiml/data/trialmind.db
aiml/data/trialmind.db-wal
aiml/data/trialmind.db-shm

# Runtime audit log — written live as the app runs (starts empty). Not source.
aiml/data/audit_trail.json
